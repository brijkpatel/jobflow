{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jobflow.dev/contracts/kafka/schemas/resume-parsed.json",
  "title": "resume-parsed",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resume_id",
    "user_id",
    "tenant_id",
    "chunk_count",
    "parsed_at"
  ],
  "properties": {
    "resume_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "chunk_count": {
      "type": "integer",
      "minimum": 0
    },
    "parsed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
